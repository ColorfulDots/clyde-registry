{
  "id": "notion",
  "displayName": "Notion",
  "description": "Deep link into Notion pages and workspaces.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.notion.so",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/notion-notes-docs-tasks/id1559269364",
  "color": "#000000",
  "icon": "squares-four",
  "tags": [
    "productivity",
    "notes",
    "notion"
  ],
  "commands": [
    {
      "name": "Open Notion",
      "keywords": [
        "notion",
        "open",
        "notes",
        "workspace"
      ],
      "executor": "urlScheme",
      "target": "notion://",
      "description": "Launch Notion and open your workspace"
    },
    {
      "name": "New Notion Page",
      "keywords": [
        "notion",
        "new",
        "page",
        "create"
      ],
      "executor": "urlScheme",
      "target": "notion://new",
      "description": "Create a new page in Notion"
    },
    {
      "name": "Notion Search",
      "keywords": [
        "notion",
        "search",
        "find",
        "page"
      ],
      "executor": "urlScheme",
      "target": "notion://search",
      "description": "Open Notion with quick search focused"
    }
  ]
}