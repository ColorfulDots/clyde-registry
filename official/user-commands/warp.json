{
  "id": "warp",
  "displayName": "Warp",
  "description": "Launch Warp terminal.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.warp.dev",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#01A4FF",
  "icon": "terminal-window",
  "tags": [
    "developer",
    "terminal",
    "warp"
  ],
  "commands": [
    {
      "name": "Open Warp",
      "keywords": [
        "warp",
        "terminal",
        "shell",
        "open"
      ],
      "executor": "shell",
      "target": "open -a Warp",
      "description": "Launch the Warp terminal"
    },
    {
      "name": "Open Project in Warp",
      "keywords": [
        "warp",
        "project",
        "workspace",
        "open",
        "terminal"
      ],
      "executor": "shell",
      "target": "open -a Warp '{{workspace_path}}'",
      "description": "Open the current project folder in Warp"
    },
    {
      "name": "New Warp Window",
      "keywords": [
        "warp",
        "new",
        "window",
        "terminal"
      ],
      "executor": "urlScheme",
      "target": "warp://new-window",
      "description": "Open a new Warp terminal window"
    }
  ]
}