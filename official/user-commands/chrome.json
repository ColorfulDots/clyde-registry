{
  "id": "chrome",
  "displayName": "Google Chrome",
  "description": "Deep link into Google Chrome.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.google.com/chrome",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "blue",
  "icon": "globe",
  "tags": [
    "browser",
    "productivity"
  ],
  "commands": [
    {
      "name": "Open Chrome",
      "keywords": [
        "chrome",
        "browser",
        "google",
        "open"
      ],
      "executor": "shell",
      "target": "open -a 'Google Chrome'",
      "description": "Launch Google Chrome"
    },
    {
      "name": "Chrome New Tab",
      "keywords": [
        "chrome",
        "new",
        "tab",
        "browser"
      ],
      "executor": "urlScheme",
      "target": "googlechrome://newtab",
      "description": "Open a new tab in Google Chrome"
    },
    {
      "name": "Chrome Incognito",
      "keywords": [
        "chrome",
        "incognito",
        "private",
        "browser"
      ],
      "executor": "shell",
      "target": "open -a 'Google Chrome' --args --incognito",
      "description": "Open a new incognito window in Chrome"
    },
    {
      "name": "Chrome Extensions",
      "keywords": [
        "chrome",
        "extensions",
        "plugins",
        "addons"
      ],
      "executor": "urlScheme",
      "target": "googlechrome://extensions",
      "description": "Open the Chrome extensions page"
    },
    {
      "name": "Chrome Settings",
      "keywords": [
        "chrome",
        "settings",
        "preferences"
      ],
      "executor": "urlScheme",
      "target": "googlechrome://settings",
      "description": "Open Chrome settings"
    }
  ]
}