{
  "id": "ticktick",
  "displayName": "TickTick",
  "description": "Deep link into TickTick for task and habit management.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://ticktick.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/ticktick-to-do-list-planner/id966085870",
  "color": "#4772FA",
  "icon": "check-fat",
  "tags": [
    "productivity",
    "tasks",
    "habits",
    "ticktick"
  ],
  "commands": [
    {
      "name": "TickTick Today",
      "keywords": [
        "ticktick",
        "today",
        "tasks",
        "daily"
      ],
      "executor": "urlScheme",
      "target": "ticktick://v1/show?smartlist=today",
      "description": "Open your Today view in TickTick"
    },
    {
      "name": "Quick Add TickTick Task",
      "keywords": [
        "ticktick",
        "add",
        "new",
        "task",
        "quick"
      ],
      "executor": "urlScheme",
      "target": "ticktick://x-callback-url/v1/add_task?title=",
      "description": "Open the quick add dialog in TickTick"
    },
    {
      "name": "TickTick Search",
      "keywords": [
        "ticktick",
        "search",
        "find",
        "task"
      ],
      "executor": "urlScheme",
      "target": "ticktick://v1/search?keyword=",
      "description": "Open TickTick search"
    }
  ]
}
