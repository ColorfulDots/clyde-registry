{
  "id": "loom",
  "displayName": "Loom",
  "description": "Record and share screen recordings with Loom.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.loom.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/loom-screen-recorder/id1474480829",
  "color": "#625DF5",
  "icon": "record",
  "tags": [
    "productivity",
    "screen recording",
    "video"
  ],
  "commands": [
    {
      "name": "Open Loom",
      "keywords": [
        "loom",
        "record",
        "screen",
        "video"
      ],
      "executor": "shell",
      "target": "open -a Loom",
      "description": "Launch the Loom screen recorder"
    },
    {
      "name": "Start Loom Recording",
      "keywords": [
        "loom",
        "record",
        "start",
        "screen capture"
      ],
      "executor": "urlScheme",
      "target": "loom://record",
      "description": "Start a new Loom screen recording immediately"
    },
    {
      "name": "My Loom Videos",
      "keywords": [
        "loom",
        "videos",
        "library",
        "recordings"
      ],
      "executor": "urlScheme",
      "target": "https://www.loom.com/my-videos",
      "description": "Open your Loom video library in the browser"
    }
  ]
}