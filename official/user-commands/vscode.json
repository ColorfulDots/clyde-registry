{
  "id": "vscode",
  "displayName": "VS Code",
  "description": "Launch Visual Studio Code.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://code.visualstudio.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#007ACC",
  "icon": "code",
  "tags": [
    "developer",
    "editor"
  ],
  "commands": [
    {
      "name": "Open VS Code",
      "keywords": [
        "vscode",
        "code",
        "editor"
      ],
      "executor": "shell",
      "target": "open -a 'Visual Studio Code'",
      "description": "Launch Visual Studio Code"
    },
    {
      "name": "Open Project in VS Code",
      "keywords": [
        "vscode",
        "code",
        "editor",
        "project",
        "workspace"
      ],
      "executor": "shell",
      "target": "open -a 'Visual Studio Code' '{{workspace_path}}'",
      "description": "Open the current project folder in VS Code"
    }
  ]
}