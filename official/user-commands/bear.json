{
  "id": "bear",
  "displayName": "Bear",
  "description": "Deep link into Bear notes app.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://bear.app",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/bear/id1091189122",
  "color": "#E6392B",
  "icon": "note-pencil",
  "tags": [
    "productivity",
    "notes",
    "writing"
  ],
  "commands": [
    {
      "name": "New Bear Note",
      "keywords": [
        "bear",
        "new",
        "note",
        "create",
        "write"
      ],
      "executor": "urlScheme",
      "target": "bear://x-callback-url/create?title=New%20Note",
      "description": "Create a new note in Bear"
    },
    {
      "name": "Bear Search",
      "keywords": [
        "bear",
        "search",
        "find",
        "note"
      ],
      "executor": "urlScheme",
      "target": "bear://x-callback-url/search",
      "description": "Open Bear with the search dialog"
    },
    {
      "name": "Bear Today",
      "keywords": [
        "bear",
        "today",
        "daily",
        "note"
      ],
      "executor": "urlScheme",
      "target": "bear://x-callback-url/today",
      "description": "Open today's notes in Bear"
    },
    {
      "name": "Bear Tags",
      "keywords": [
        "bear",
        "tags",
        "browse",
        "organize"
      ],
      "executor": "urlScheme",
      "target": "bear://x-callback-url/tags",
      "description": "View all tags in Bear"
    }
  ]
}
