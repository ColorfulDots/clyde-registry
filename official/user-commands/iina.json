{
  "id": "iina",
  "displayName": "IINA",
  "description": "Launch IINA video player.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://iina.io",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#00B5CC",
  "icon": "play-circle",
  "tags": [
    "media",
    "video",
    "player"
  ],
  "commands": [
    {
      "name": "Open IINA",
      "keywords": [
        "iina",
        "video",
        "player",
        "open"
      ],
      "executor": "shell",
      "target": "open -a IINA",
      "description": "Launch the IINA video player"
    },
    {
      "name": "IINA Open URL",
      "keywords": [
        "iina",
        "url",
        "stream",
        "video",
        "play"
      ],
      "executor": "urlScheme",
      "target": "iina://open",
      "description": "Open a URL or stream in IINA"
    }
  ]
}