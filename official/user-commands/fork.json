{
  "id": "fork",
  "displayName": "Fork",
  "description": "Launch Fork Git client.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://git-fork.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "blue",
  "icon": "arrow.triangle.branch",
  "tags": [
    "developer",
    "git",
    "fork"
  ],
  "commands": [
    {
      "name": "Open Fork",
      "keywords": [
        "fork",
        "git",
        "open",
        "repos"
      ],
      "executor": "shell",
      "target": "open -a Fork",
      "description": "Launch the Fork Git client"
    },
    {
      "name": "Open Project in Fork",
      "keywords": [
        "fork",
        "git",
        "open",
        "project",
        "workspace"
      ],
      "executor": "shell",
      "target": "open -a Fork '{{workspace_path}}'",
      "description": "Open the current project in Fork"
    },
    {
      "name": "Fork New Repository",
      "keywords": [
        "fork",
        "git",
        "new",
        "repo",
        "clone"
      ],
      "executor": "urlScheme",
      "target": "fork://clone",
      "description": "Open the clone/new repository dialog in Fork"
    }
  ]
}