{
  "id": "reminders",
  "displayName": "Reminders",
  "description": "Deep link into Apple Reminders.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://apps.apple.com/app/reminders/id1108187841",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#FF3B30",
  "icon": "bell",
  "tags": [
    "productivity",
    "tasks",
    "apple"
  ],
  "commands": [
    {
      "name": "Open Reminders",
      "keywords": [
        "reminders",
        "tasks",
        "todos",
        "open"
      ],
      "executor": "shell",
      "target": "open -a Reminders",
      "description": "Launch the Apple Reminders app"
    },
    {
      "name": "New Reminder",
      "keywords": [
        "reminders",
        "new",
        "add",
        "create",
        "task"
      ],
      "executor": "applescript",
      "target": "tell application \"Reminders\"\nactivate\nmake new reminder\nend tell",
      "description": "Create a new reminder in Apple Reminders"
    }
  ]
}