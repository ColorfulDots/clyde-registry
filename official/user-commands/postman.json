{
  "id": "postman",
  "displayName": "Postman",
  "description": "Launch Postman for API development and testing.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.postman.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#FF6C37",
  "icon": "paper-plane-tilt",
  "tags": [
    "developer",
    "api",
    "testing"
  ],
  "commands": [
    {
      "name": "Open Postman",
      "keywords": [
        "postman",
        "api",
        "rest",
        "http"
      ],
      "executor": "shell",
      "target": "open -a Postman",
      "description": "Launch the Postman API client"
    },
    {
      "name": "New Postman Request",
      "keywords": [
        "postman",
        "new",
        "request",
        "api",
        "http"
      ],
      "executor": "urlScheme",
      "target": "postman://new/request",
      "description": "Open a new API request tab in Postman"
    },
    {
      "name": "Postman Collections",
      "keywords": [
        "postman",
        "collections",
        "api",
        "browse"
      ],
      "executor": "urlScheme",
      "target": "postman://collections",
      "description": "Open your Postman collections"
    }
  ]
}