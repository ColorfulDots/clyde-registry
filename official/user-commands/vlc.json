{
  "id": "vlc",
  "displayName": "VLC",
  "description": "Launch VLC media player.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.videolan.org/vlc",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/vlc-media-player/id650377962",
  "color": "#FF8800",
  "icon": "play-circle",
  "tags": [
    "media",
    "video",
    "player"
  ],
  "commands": [
    {
      "name": "Open VLC",
      "keywords": [
        "vlc",
        "video",
        "player",
        "open",
        "media"
      ],
      "executor": "shell",
      "target": "open -a VLC",
      "description": "Launch VLC media player"
    },
    {
      "name": "VLC Open Network Stream",
      "keywords": [
        "vlc",
        "stream",
        "network",
        "url",
        "play"
      ],
      "executor": "urlScheme",
      "target": "vlc://",
      "description": "Open a network stream in VLC"
    }
  ]
}