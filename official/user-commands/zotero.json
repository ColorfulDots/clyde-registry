{
  "id": "zotero",
  "displayName": "Zotero",
  "description": "Deep link into Zotero for research and citations.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.zotero.org",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#CC2936",
  "icon": "graduation-cap",
  "tags": [
    "research",
    "productivity",
    "citations",
    "academic"
  ],
  "commands": [
    {
      "name": "Open Zotero",
      "keywords": [
        "zotero",
        "research",
        "citations",
        "open"
      ],
      "executor": "urlScheme",
      "target": "zotero://",
      "description": "Launch Zotero reference manager"
    },
    {
      "name": "Zotero Search",
      "keywords": [
        "zotero",
        "search",
        "find",
        "reference",
        "paper"
      ],
      "executor": "urlScheme",
      "target": "zotero://search",
      "description": "Open Zotero with search focused"
    },
    {
      "name": "New Zotero Item",
      "keywords": [
        "zotero",
        "new",
        "item",
        "add",
        "reference"
      ],
      "executor": "urlScheme",
      "target": "zotero://new",
      "description": "Add a new item to your Zotero library"
    }
  ]
}