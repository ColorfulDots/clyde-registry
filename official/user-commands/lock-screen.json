{
  "id": "lock-screen",
  "displayName": "Lock Screen",
  "description": "Lock your Mac screen immediately.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://github.com/ColorfulDots/clyde-registry",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#6E6E73",
