{
  "id": "drafts",
  "displayName": "Drafts",
  "description": "Deep link into Drafts for quick capture and actions.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://getdrafts.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/drafts/id1435957248",
  "color": "#2B2B2B",
  "icon": "pencil-line",
  "tags": [
    "productivity",
    "notes",
    "writing",
    "capture"
  ],
  "commands": [
    {
      "name": "New Draft",
      "keywords": [
        "drafts",
        "new",
        "note",
        "capture",
        "write"
      ],
      "executor": "urlScheme",
      "target": "drafts://x-callback-url/create?text=",
      "description": "Open a new blank draft in Drafts"
    },
    {
      "name": "Drafts Quick Search",
      "keywords": [
        "drafts",
        "search",
        "find",
        "note"
      ],
      "executor": "urlScheme",
      "target": "drafts://x-callback-url/quickSearch",
      "description": "Open Drafts with the quick search bar focused"
    },
    {
      "name": "Drafts Capture from Clipboard",
      "keywords": [
        "drafts",
        "clipboard",
        "capture",
        "paste"
      ],
      "executor": "urlScheme",
      "target": "drafts://x-callback-url/create?text=%7C%7Cclipboard%7C%7C",
      "description": "Create a new draft from your clipboard contents"
    },
    {
      "name": "Drafts Dictation",
      "keywords": [
        "drafts",
        "dictate",
        "voice",
        "speech"
      ],
      "executor": "urlScheme",
      "target": "drafts://x-callback-url/dictate",
      "description": "Open Drafts in dictation mode"
    }
  ]
}
