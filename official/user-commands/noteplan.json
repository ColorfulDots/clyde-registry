{
  "id": "noteplan",
  "displayName": "NotePlan",
  "description": "Deep link into NotePlan for daily planning and notes.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://noteplan.co",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/noteplan-3-markdown-planner/id1505432629",
  "color": "#E8453C",
  "icon": "calendar-check",
  "tags": [
    "productivity",
    "notes",
    "planning",
    "calendar"
  ],
  "commands": [
    {
      "name": "Open NotePlan",
      "keywords": [
        "noteplan",
        "notes",
        "planning",
        "open"
      ],
      "executor": "urlScheme",
      "target": "noteplan://",
      "description": "Launch NotePlan"
    },
    {
      "name": "NotePlan Today",
      "keywords": [
        "noteplan",
        "today",
        "daily",
        "note"
      ],
      "executor": "urlScheme",
      "target": "noteplan://today",
      "description": "Open today's daily note in NotePlan"
    },
    {
      "name": "New NotePlan Note",
      "keywords": [
        "noteplan",
        "new",
        "note",
        "create"
      ],
      "executor": "urlScheme",
      "target": "noteplan://new",
      "description": "Create a new note in NotePlan"
    }
  ]
}