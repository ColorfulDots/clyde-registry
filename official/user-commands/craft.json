{
  "id": "craft",
  "displayName": "Craft",
  "description": "Deep link into Craft docs and notes.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://www.craft.do",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/craft-docs-and-notes-editor/id1487937127",
  "color": "#1B6BFF",
  "icon": "file-text",
  "tags": [
    "productivity",
    "notes",
    "writing",
    "docs"
  ],
  "commands": [
    {
      "name": "Open Craft",
      "keywords": [
        "craft",
        "notes",
        "docs",
        "open"
      ],
      "executor": "urlScheme",
      "target": "craftdocs://",
      "description": "Launch the Craft docs app"
    },
    {
      "name": "New Craft Document",
      "keywords": [
        "craft",
        "new",
        "document",
        "create",
        "note"
      ],
      "executor": "urlScheme",
      "target": "craftdocs://createdocument",
      "description": "Create a new document in Craft"
    },
    {
      "name": "Craft Search",
      "keywords": [
        "craft",
        "search",
        "find",
        "document"
      ],
      "executor": "urlScheme",
      "target": "craftdocs://search",
      "description": "Open Craft with the search panel focused"
    }
  ]
}