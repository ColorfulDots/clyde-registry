{
  "id": "omnifocus",
  "displayName": "OmniFocus",
  "description": "Deep link into OmniFocus for advanced task management.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.omnigroup.com/omnifocus",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/omnifocus-4/id1542143627",
  "color": "#7A2FF7",
  "icon": "check-circle",
  "tags": [
    "productivity",
    "tasks",
    "omnifocus"
  ],
  "commands": [
    {
      "name": "OmniFocus Inbox",
      "keywords": [
        "omnifocus",
        "inbox",
        "capture",
        "tasks"
      ],
      "executor": "urlScheme",
      "target": "omnifocus:///inbox",
      "description": "Open your OmniFocus Inbox"
    },
    {
      "name": "OmniFocus Forecast",
      "keywords": [
        "omnifocus",
        "today",
        "forecast",
        "tasks"
      ],
      "executor": "urlScheme",
      "target": "omnifocus:///perspective/Forecast",
      "description": "Open the OmniFocus Forecast perspective"
    },
    {
      "name": "New OmniFocus Task",
      "keywords": [
        "omnifocus",
        "new",
        "task",
        "add",
        "create"
      ],
      "executor": "urlScheme",
      "target": "omnifocus:///add",
      "description": "Open the quick entry dialog in OmniFocus"
    },
    {
      "name": "OmniFocus Projects",
      "keywords": [
        "omnifocus",
        "projects",
        "browse"
      ],
      "executor": "urlScheme",
      "target": "omnifocus:///perspective/Projects",
      "description": "Open the Projects perspective in OmniFocus"
    },
    {
      "name": "OmniFocus Review",
      "keywords": [
        "omnifocus",
        "review",
        "weekly"
      ],
      "executor": "urlScheme",
      "target": "omnifocus:///perspective/Review",
      "description": "Open the Review perspective in OmniFocus"
    }
  ]
}
