{
  "id": "maps",
  "displayName": "Apple Maps",
  "description": "Deep link into Apple Maps for navigation.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://maps.apple.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#34C759",
  "icon": "map-pin",
  "tags": [
    "navigation",
    "maps",
    "productivity"
  ],
  "commands": [
    {
      "name": "Open Maps",
      "keywords": [
        "maps",
        "navigation",
        "directions",
        "open"
      ],
      "executor": "shell",
      "target": "open -a Maps",
      "description": "Launch Apple Maps"
    },
    {
      "name": "Get Directions Home",
      "keywords": [
        "maps",
        "home",
        "directions",
        "navigate"
      ],
      "executor": "urlScheme",
      "target": "maps://?daddr=Home&dirflg=d",
      "description": "Get driving directions to your saved Home address"
    },
    {
      "name": "Get Directions to Work",
      "keywords": [
        "maps",
        "work",
        "directions",
        "navigate",
        "office"
      ],
      "executor": "urlScheme",
      "target": "maps://?daddr=Work&dirflg=d",
      "description": "Get driving directions to your saved Work address"
    },
    {
      "name": "Search Nearby",
      "keywords": [
        "maps",
        "nearby",
        "search",
        "find",
        "local"
      ],
      "executor": "urlScheme",
      "target": "maps://?near=me",
      "description": "Search for places near your current location in Maps"
    }
  ]
}