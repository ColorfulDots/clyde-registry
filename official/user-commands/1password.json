{
  "id": "1password",
  "displayName": "1Password",
  "description": "Deep link into 1Password to access your vault.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://1password.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "color": "blue",
  "icon": "lock.fill",
  "tags": [
    "productivity",
    "security",
    "passwords"
  ],
  "commands": [
    {
      "name": "Open 1Password",
      "keywords": [
        "1password",
        "passwords",
        "vault",
        "login"
      ],
      "executor": "urlScheme",
      "target": "onepassword://",
      "description": "Launch 1Password and open your vault"
    },
    {
      "name": "1Password Search",
      "keywords": [
        "1password",
        "search",
        "find",
        "login",
        "password"
      ],
      "executor": "urlScheme",
      "target": "onepassword://search/",
      "description": "Open 1Password with search focused to find a login"
    },
    {
      "name": "New 1Password Item",
      "keywords": [
        "1password",
        "new",
        "add",
        "create",
        "login"
      ],
      "executor": "urlScheme",
      "target": "onepassword://new",
      "description": "Create a new item in your 1Password vault"
    }
  ]
}