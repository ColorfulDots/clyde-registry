{
  "id": "facetime",
  "displayName": "FaceTime",
  "description": "Start FaceTime audio and video calls.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://apps.apple.com/app/facetime/id1110145091",
