{
  "id": "signal",
  "displayName": "Signal",
  "description": "Deep link into Signal for private messaging.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://signal.org",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/signal-private-messenger/id874139669",
  "color": "#3A76F0",
  "icon": "chat-lock",
  "tags": [
    "communication",
    "messaging",
    "privacy",
    "signal"
  ],
  "commands": [
    {
      "name": "Open Signal",
      "keywords": [
        "signal",
        "messages",
        "private",
        "open"
      ],
      "executor": "urlScheme",
      "target": "sgnl://",
      "description": "Launch Signal private messenger"
    },
    {
      "name": "New Signal Message",
      "keywords": [
        "signal",
        "new",
        "message",
        "compose"
      ],
      "executor": "urlScheme",
      "target": "sgnl://compose",
      "description": "Start a new message in Signal"
    }
  ]
}