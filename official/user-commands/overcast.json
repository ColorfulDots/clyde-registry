{
  "id": "overcast",
  "displayName": "Overcast",
  "description": "Deep link into Overcast podcast player.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://overcast.fm",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "color": "orange",
  "icon": "headphones",
  "tags": [
    "media",
    "podcasts",
    "audio"
  ],
  "commands": [
    {
      "name": "Open Overcast",
      "keywords": [
        "overcast",
        "podcasts",
        "audio",
        "open"
      ],
      "executor": "urlScheme",
      "target": "overcast://",
      "description": "Launch Overcast podcast player"
    },
    {
      "name": "Overcast Now Playing",
      "keywords": [
        "overcast",
        "now playing",
        "podcast",
        "listen"
      ],
      "executor": "urlScheme",
      "target": "overcast://now-playing",
      "description": "Jump to the now playing episode in Overcast"
    }
  ]
}