{
  "id": "tower",
  "displayName": "Tower",
  "description": "Launch Tower Git client.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.git-tower.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/tower-git-client/id1449505718",
  "color": "#6494C2",
  "icon": "git-branch",
  "tags": [
    "developer",
    "git",
    "tower"
  ],
  "commands": [
    {
      "name": "Open Tower",
      "keywords": [
        "tower",
        "git",
        "open",
        "repos"
      ],
      "executor": "shell",
      "target": "open -a Tower",
      "description": "Launch the Tower Git client"
    },
    {
      "name": "Open Project in Tower",
      "keywords": [
        "tower",
        "git",
        "open",
        "project",
        "workspace"
      ],
      "executor": "shell",
      "target": "open -a Tower '{{workspace_path}}'",
      "description": "Open the current project in Tower"
    }
  ]
}
