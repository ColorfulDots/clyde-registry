{
  "id": "telegram",
  "displayName": "Telegram",
  "description": "Deep link into Telegram chats and contacts.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://telegram.org",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/telegram/id747648890",
  "color": "#2AABEE",
  "icon": "telegram-logo",
  "tags": [
    "communication",
    "messaging",
    "telegram"
  ],
  "commands": [
    {
      "name": "Open Telegram",
      "keywords": [
        "telegram",
        "open",
        "chat",
        "messages"
      ],
      "executor": "urlScheme",
      "target": "tg://",
      "description": "Launch the Telegram app"
    },
    {
      "name": "Telegram Settings",
      "keywords": [
        "telegram",
        "settings",
        "preferences"
      ],
      "executor": "urlScheme",
      "target": "tg://settings",
      "description": "Open Telegram settings"
    },
    {
      "name": "New Telegram Message",
      "keywords": [
        "telegram",
        "new",
        "message",
        "compose"
      ],
      "executor": "urlScheme",
      "target": "tg://msg",
      "description": "Start a new message in Telegram"
    }
  ]
}