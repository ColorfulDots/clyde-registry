{
  "id": "app-store",
  "displayName": "App Store",
  "description": "Deep link into the macOS App Store.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.apple.com/app-store",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#0D84FF",
  "icon": "app-store-logo",
  "tags": [
    "system",
    "apps",
    "apple"
  ],
  "commands": [
    {
      "name": "Open App Store",
      "keywords": [
        "app store",
        "apps",
        "download",
        "open"
      ],
      "executor": "urlScheme",
      "target": "macappstore://",
      "description": "Launch the macOS App Store"
    },
    {
      "name": "App Store Updates",
      "keywords": [
        "app store",
        "updates",
        "upgrade",
        "apps"
      ],
      "executor": "urlScheme",
      "target": "macappstore://updates",
      "description": "Open the Updates tab in the App Store"
    },
    {
      "name": "App Store Featured",
      "keywords": [
        "app store",
        "featured",
        "discover",
        "apps"
      ],
      "executor": "urlScheme",
      "target": "macappstore://featured",
      "description": "Browse featured apps in the App Store"
    }
  ]
}