{
  "id": "app-store",
  "displayName": "App Store",
  "description": "Deep link into the macOS App Store.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.apple.com/app-store",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": null,
  "color": "#0D84FF",
  "icon": "app-store-logo",
  "tags": [
    "system",
    "apps",
    "apple"
  ],
  "commands": [
    {
      "name": "App Store Updates",
      "keywords": [
        "app store",
        "updates",
        "upgrade",
        "apps"
      ],
      "executor": "urlScheme",
      "target": "macappstore://showUpdatesPage",
      "description": "Open the Updates page in the App Store"
    },
    {
      "name": "App Store Purchased",
      "keywords": [
        "app store",
        "purchased",
        "bought",
        "apps"
      ],
      "executor": "urlScheme",
      "target": "macappstore://showPurchasesPage",
      "description": "Open the Purchased page in the App Store"
    }
  ]
}
