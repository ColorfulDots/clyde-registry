{
  "id": "xcode",
  "displayName": "Xcode",
  "description": "Launch Xcode and open developer tools.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://developer.apple.com/xcode",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/xcode/id497799835",
  "color": "blue",
  "icon": "hammer.fill",
  "tags": [
    "developer",
    "xcode",
    "ios",
    "macos"
  ],
  "commands": [
    {
      "name": "Open Xcode",
      "keywords": [
        "xcode",
        "open",
        "ide",
        "developer"
      ],
      "executor": "shell",
      "target": "open -a Xcode",
      "description": "Launch Xcode IDE"
    },
    {
      "name": "Open Simulator",
      "keywords": [
        "simulator",
        "ios",
        "xcode",
        "iphone"
      ],
      "executor": "shell",
      "target": "open -a Simulator",
      "description": "Launch the iOS Simulator"
    },
    {
      "name": "Clear Derived Data",
      "keywords": [
        "xcode",
        "derived data",
        "clean",
        "cache",
        "build"
      ],
      "executor": "shell",
      "target": "osascript -e 'tell app \"Terminal\" to do script \"rm -rf ~/Library/Developer/Xcode/DerivedData\"'",
      "description": "Delete Xcode's DerivedData folder to force a clean build"
    },
    {
      "name": "Xcode Build",
      "keywords": [
        "xcode",
        "build",
        "compile",
        "xcodebuild"
      ],
      "executor": "shell",
      "target": "osascript -e 'tell app \"Terminal\" to do script \"xcodebuild build\"'",
      "description": "Run xcodebuild to compile the current project"
    }
  ]
}