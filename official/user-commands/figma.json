{
  "id": "figma",
  "displayName": "Figma",
  "description": "Launch Figma for design.",
  "version": "1.0.0",
  "author": "ColorfulDots",
  "homepage": "https://www.figma.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "appStore": "https://apps.apple.com/app/figma/id1152002983",
  "color": "#F24E1E",
  "icon": "figma-logo",
  "tags": [
    "design",
    "developer",
    "figma"
  ],
  "commands": [
    {
      "name": "Open Figma",
      "keywords": [
        "figma",
        "open",
        "design"
      ],
      "executor": "shell",
      "target": "open -a Figma",
      "description": "Launch the Figma desktop app"
    },
    {
      "name": "Figma Community",
      "keywords": [
        "figma",
        "community",
        "plugins",
        "templates"
      ],
      "executor": "urlScheme",
      "target": "https://www.figma.com/community",
      "description": "Browse the Figma Community for templates and plugins"
    }
  ]
}
