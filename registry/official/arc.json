{
  "module": "arc",
  "displayName": "Arc Browser",
  "description": "Deep link into Arc browser features.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://github.com/ColorfulDots/clyde-registry",
  "color": "purple",
  "icon": "globe",
  "tags": ["browser", "productivity"],
  "commands": [
    {
      "name": "Open Arc",
      "keywords": ["arc", "browser", "open"],
      "executor": "shell",
      "target": "open -a Arc",
      "description": "Launch the Arc browser"
    },
    {
      "name": "New Arc Window",
      "keywords": ["arc", "new", "window", "browser"],
      "executor": "urlScheme",
      "target": "arc://new-window",
      "description": "Open a new Arc browser window"
    },
    {
      "name": "Arc Command Bar",
      "keywords": ["arc", "command", "search", "bar"],
      "executor": "urlScheme",
      "target": "arc://command-bar",
      "description": "Open the Arc command bar"
    }
  ]
}
