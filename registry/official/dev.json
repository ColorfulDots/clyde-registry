{
  "module": "dev",
  "displayName": "Dev Tools",
  "description": "Open your dev tools, editors, and local servers fast.",
  "color": "blue",
  "icon": "terminal",
  "commands": [
    {
      "name": "Open Terminal",
      "keywords": ["terminal", "shell", "bash", "zsh"],
      "executor": "shell",
      "target": "open -a Terminal",
      "description": "Launch Terminal.app"
    },
    {
      "name": "Open VS Code",
      "keywords": ["vscode", "code", "editor"],
      "executor": "shell",
      "target": "open -a 'Visual Studio Code'",
      "description": "Launch Visual Studio Code"
    },
    {
      "name": "Open GitHub",
      "keywords": ["github", "git", "repo"],
      "executor": "urlScheme",
      "target": "https://github.com",
      "description": "Open GitHub in browser"
    },
    {
      "name": "Localhost 3000",
      "keywords": ["localhost", "local", "dev server", "3000"],
      "executor": "urlScheme",
      "target": "http://localhost:3000",
      "description": "Open localhost:3000 in browser"
    },
    {
      "name": "Localhost 8080",
      "keywords": ["localhost", "local", "8080"],
      "executor": "urlScheme",
      "target": "http://localhost:8080",
      "description": "Open localhost:8080 in browser"
    }
  ]
}
