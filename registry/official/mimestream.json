{
  "id": "mimestream",
  "displayName": "Mimestream",
  "description": "Deep link into Mimestream Gmail client.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://github.com/ColorfulDots/clyde-registry",
  "color": "blue",
  "icon": "envelope.fill",
  "tags": ["productivity", "email", "gmail"],
  "commands": [
    {
      "name": "Open Mimestream",
      "keywords": ["mimestream", "email", "gmail", "inbox"],
      "executor": "shell",
      "target": "open -a Mimestream",
      "description": "Launch Mimestream Gmail client"
    },
    {
      "name": "Compose Mimestream Email",
      "keywords": ["mimestream", "compose", "new", "email", "write"],
      "executor": "urlScheme",
      "target": "mimestream://compose",
      "description": "Open a new compose window in Mimestream"
    }
  ]
}
