      "description": "Launch Apple Messages"
    },
    {
      "name": "New Message",
      "keywords": ["messages", "new", "sms", "imessage", "compose"],
      "executor": "urlScheme",
      "target": "sms:",
      "description": "Open a new message compose window"
    }
  ]
}
