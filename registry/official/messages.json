{
  "id": "messages",
  "displayName": "Messages",
  "description": "Deep link into Apple Messages.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://github.com/ColorfulDots/clyde-registry",
  "color": "green",
  "icon": "message.fill",
  "tags": ["communication", "messaging", "apple"],
  "commands": [
    {
      "name": "Open Messages",
      "keywords": ["messages", "imessage", "sms", "open"],
      "executor": "shell",
