    },
    {
      "name": "VLC Open Network Stream",
      "keywords": ["vlc", "stream", "network", "url", "play"],
      "executor": "urlScheme",
      "target": "vlc://",
      "description": "Open a network stream in VLC"
    }
  ]
}
