{
  "module": "vlc",
  "displayName": "VLC",
  "description": "Launch VLC media player.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://github.com/ColorfulDots/clyde-registry",
  "color": "orange",
  "icon": "play.fill",
  "tags": ["media", "video", "player"],
