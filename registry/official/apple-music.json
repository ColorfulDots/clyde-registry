{
  "id": "apple-music",
  "displayName": "Apple Music",
  "description": "Control Apple Music playback via AppleScript.",
  "version": "1.0.0",
  "author": "colorfulDots",
  "homepage": "https://music.apple.com",
  "registry": "https://github.com/ColorfulDots/clyde-registry",
  "color": "red",
  "icon": "music.note",
  "tags": [
    "music",
    "productivity",
    "apple"
  ],
  "commands": [
    {
      "name": "Open Apple Music",
      "keywords": [
        "apple music",
        "music",
        "open"
      ],
      "executor": "shell",
      "target": "open -a Music",
      "description": "Launch the Apple Music app"
    },
    {
      "name": "Play / Pause Music",
      "keywords": [
        "music",
        "play",
        "pause",
        "apple music"
      ],
      "executor": "applescript",
      "target": "tell application \"Music\" to playpause",
      "description": "Toggle play/pause in Apple Music"
    },
    {
      "name": "Apple Music Next Track",
      "keywords": [
        "music",
        "next",
        "skip",
        "track",
        "apple music"
      ],
      "executor": "applescript",
      "target": "tell application \"Music\" to next track",
      "description": "Skip to the next track in Apple Music"
    },
    {
      "name": "Apple Music Previous Track",
      "keywords": [
        "music",
        "previous",
        "back",
        "track",
        "apple music"
      ],
      "executor": "applescript",
      "target": "tell application \"Music\" to previous track",
      "description": "Go back to the previous track in Apple Music"
    },
    {
      "name": "Now Playing",
      "keywords": [
        "music",
        "now playing",
        "current",
        "song"
      ],
      "executor": "applescript",
      "target": "tell application \"Music\"\nset t to name of current track\nset a to artist of current track\ndisplay notification t with title a\nend tell",
      "description": "Show a notification with the currently playing song and artist"
    }
  ]
}